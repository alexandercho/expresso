{
    "name": "backend",
    "version": "1.0.0",
    "private": true,
    "description": "Minimal Express backend skeleton with placeholder CRUD routes and a health check.",
    "main": "src/server.js",
    "packageManager": "pnpm@10.12.1",
    "engines": {
        "node": "26.x"
    },
    "imports": {
        "#app": "./src/app.js",
        "#controllers/*": "./src/controllers/*.js",
        "#data/*": "./src/data/*.js",
        "#middleware/*": "./src/middleware/*.js",
        "#routes": "./src/routes/index.js",
        "#routes/*": "./src/routes/*.js",
        "#utils/*": "./src/utils/*.js"
    },
    "scripts": {
        "start": "\"$npm_node_execpath\" src/server.js",
        "dev": "\"$npm_node_execpath\" --watch src/server.js",
        "lint": "\"$npm_node_execpath\" ./node_modules/eslint/bin/eslint.js src",
        "lint:fix": "\"$npm_node_execpath\" ./node_modules/eslint/bin/eslint.js src --fix",
        "test:api": "\"$npm_node_execpath\" --test tests/api/*.test.js",
        "test:api:frontend": "\"$npm_node_execpath\" --test tests/api/frontend-contract.test.js",
        "test:api:latest": "\"$npm_node_execpath\" --test tests/api/latest.test.js",
        "test:api:legacy": "\"$npm_node_execpath\" --test tests/api/legacy.test.js",
        "test:api:deprecated": "\"$npm_node_execpath\" --test tests/api/deprecated.test.js"
    },
    "dependencies": {
        "express": "^5.2.1"
    },
    "devDependencies": {
        "eslint": "^9.39.1"
    }
}
